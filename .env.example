# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string, e.g. postgresql+psycopg://user:password@localhost:5432/memory_ai
DATABASE_URL=postgresql+psycopg://memory_ai:memory_ai@localhost:5432/memory_ai

# Anthropic API key used for flashcard generation
ANTHROPIC_API_KEY=sk-ant-placeholder

# Secret used to sign/verify JWTs - generate a long random string for real use
JWT_SECRET=change-me-to-a-random-secret

# Deployment environment: development | test | production
ENVIRONMENT=development

# Access token (JWT-in-cookie) lifetime, in minutes. Default is 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080
